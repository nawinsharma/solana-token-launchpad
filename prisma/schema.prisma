generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String
  createdAt DateTime   @default(now())
  launches  Launch[]
  purchases Purchase[]
}

model Launch {
  id           String           @id @default(uuid())
  name         String
  symbol       String
  totalSupply  Float
  pricePerToken Float
  startsAt     DateTime
  endsAt       DateTime
  maxPerWallet Float
  description  String?
  creatorId    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  creator      User             @relation(fields: [creatorId], references: [id])
  tiers        Tier[]
  vesting      Vesting?
  whitelist    WhitelistEntry[]
  referrals    ReferralCode[]
  purchases    Purchase[]
}

model Tier {
  id            String @id @default(uuid())
  launchId      String
  minAmount     Float
  maxAmount     Float
  pricePerToken Float
  launch        Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)
}

model Vesting {
  id          String @id @default(uuid())
  launchId    String @unique
  cliffDays   Int
  vestingDays Int
  tgePercent  Float
  launch      Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)
}

model WhitelistEntry {
  id       String @id @default(uuid())
  launchId String
  address  String
  launch   Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@unique([launchId, address])
}

model ReferralCode {
  id              String @id @default(uuid())
  launchId        String
  code            String
  discountPercent Float
  maxUses         Int
  usedCount       Int    @default(0)
  launch          Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@unique([launchId, code])
}

model Purchase {
  id            String   @id @default(uuid())
  launchId      String
  userId        String
  walletAddress String
  amount        Float
  totalCost     Float
  txSignature   String   @unique
  referralCode  String?
  createdAt     DateTime @default(now())
  launch        Launch   @relation(fields: [launchId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])
}
